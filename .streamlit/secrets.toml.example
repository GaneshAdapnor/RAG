# Copy this to .streamlit/secrets.toml for local Streamlit runs,
# OR paste each key into the Streamlit Cloud "Secrets" panel.
# Never commit secrets.toml to git.

OPENAI_API_KEY = "sk-your-openai-api-key-here"

# Optional overrides (defaults are fine for most cases)
# LLM_MODEL_NAME       = "gpt-4o-mini"
# EMBEDDING_MODEL_NAME = "all-MiniLM-L6-v2"
# CHUNK_SIZE           = "500"
# CHUNK_OVERLAP        = "50"
# TOP_K_RETRIEVAL      = "5"

# Set this ONLY if routing through a separate FastAPI server
# STREAMLIT_API_BASE = "http://localhost:8000"
