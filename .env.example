# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM model to use for answer generation.
# Options: gpt-4o-mini (default, cheap), gpt-4o (more capable, more expensive)
LLM_MODEL_NAME=gpt-4o-mini

# ── Embedding ─────────────────────────────────────────────────────────────────
# Sentence-transformers model name (downloaded automatically from HuggingFace Hub).
# Do not change this after indexing documents — incompatible vectors will corrupt search.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=./data
FAISS_INDEX_PATH=./data/faiss_index.bin
METADATA_PATH=./data/metadata.json

# ── Chunking ──────────────────────────────────────────────────────────────────
# Characters per chunk. 500 ≈ 80-120 words. Keep below ~1500 chars for MiniLM.
CHUNK_SIZE=500
# Characters of overlap between consecutive chunks. Prevents boundary information loss.
CHUNK_OVERLAP=50

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Default number of chunks to retrieve per query.
TOP_K_RETRIEVAL=5

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Max queries per client IP per minute.
RATE_LIMIT_CALLS=10
RATE_LIMIT_PERIOD_SECONDS=60
